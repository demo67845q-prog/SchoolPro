<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="SchoolDashboard">
        <div class="school-dashboard">

            <!-- ── Header ── -->
            <div class="sd-header">
                <h2>
                    <i class="fa fa-graduation-cap me-2"/>
                    School Dashboard
                </h2>
                <div class="sd-header-right">
                    <span class="sd-updated">
                        Updated: <t t-esc="state.lastUpdated"/>
                    </span>
                    <button class="sd-refresh-btn" t-on-click="loadData">
                        <i class="fa fa-refresh"/> Refresh
                    </button>
                </div>
            </div>

            <!-- ── Loading ── -->
            <t t-if="state.loading">
                <div class="sd-loading">
                    <i class="fa fa-spinner fa-spin"/>
                    <span>Loading dashboard...</span>
                </div>
            </t>

            <t t-else="">

                <!-- ── Row 1: Student KPIs ── -->
                <div class="sd-kpi-row students">
                    <div class="sd-kpi t-blue">
                        <div class="sd-kpi-icon"><i class="fa fa-users"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.studentKpis.total_students"/>
                            <div class="sd-kpi-label">Total Students</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-green">
                        <div class="sd-kpi-icon"><i class="fa fa-check-circle"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.studentKpis.active_students"/>
                            <div class="sd-kpi-label">Active</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-cyan">
                        <div class="sd-kpi-icon"><i class="fa fa-user-plus"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.studentKpis.new_admissions"/>
                            <div class="sd-kpi-label">New Admissions</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-teal">
                        <div class="sd-kpi-icon"><i class="fa fa-calendar-check-o"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value"><t t-esc="state.studentKpis.avg_attendance"/>%</div>
                            <div class="sd-kpi-label">Attendance</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-purple">
                        <div class="sd-kpi-icon"><i class="fa fa-id-badge"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.studentKpis.total_teachers"/>
                            <div class="sd-kpi-label">Teachers</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-amber">
                        <div class="sd-kpi-icon"><i class="fa fa-building"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.studentKpis.total_classes"/>
                            <div class="sd-kpi-label">Classes</div>
                        </div>
                    </div>
                </div>

                <!-- ── Row 2: Fee KPIs ── -->
                <div class="sd-kpi-row fees">
                    <div class="sd-kpi t-blue">
                        <div class="sd-kpi-icon"><i class="fa fa-file-text-o"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.feeKpis.total_invoices"/>
                            <div class="sd-kpi-label">Total Invoices</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-green">
                        <div class="sd-kpi-icon"><i class="fa fa-check"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.feeKpis.paid_invoices"/>
                            <div class="sd-kpi-label">Paid</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-orange">
                        <div class="sd-kpi-icon"><i class="fa fa-clock-o"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.feeKpis.pending_invoices"/>
                            <div class="sd-kpi-label">Pending</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-red">
                        <div class="sd-kpi-icon"><i class="fa fa-exclamation-triangle"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.feeKpis.overdue_invoices"/>
                            <div class="sd-kpi-label">Overdue</div>
                        </div>
                    </div>
                    <div class="sd-kpi t-teal">
                        <div class="sd-kpi-icon"><i class="fa fa-money"/></div>
                        <div class="sd-kpi-text">
                            <div class="sd-kpi-value" t-esc="state.feeKpis.total_due_amount"/>
                            <div class="sd-kpi-label">Amount Due</div>
                        </div>
                    </div>
                </div>

                <!-- ── Row 3: Charts + Library ── -->
                <div class="sd-middle">
                    <div class="sd-card">
                        <div class="sd-card-title">
                            <i class="fa fa-pie-chart"/> Student Distribution
                        </div>
                        <div class="sd-chart-wrap">
                            <canvas id="schoolStudentChart"/>
                        </div>
                    </div>
                    <div class="sd-card">
                        <div class="sd-card-title">
                            <i class="fa fa-bar-chart"/> Fee Collection
                        </div>
                        <div class="sd-chart-wrap">
                            <canvas id="schoolFeeChart"/>
                        </div>
                    </div>
                    <div class="sd-card">
                        <div class="sd-card-title">
                            <i class="fa fa-book"/> Library
                        </div>
                        <div class="sd-library-panel">
                            <div class="sd-lib-item lib-total">
                                <div class="sd-lib-icon"><i class="fa fa-book"/></div>
                                <div>
                                    <div class="sd-lib-value" t-esc="state.libraryKpis.total_books"/>
                                    <div class="sd-lib-label">Total Books</div>
                                </div>
                            </div>
                            <div class="sd-lib-item lib-issued">
                                <div class="sd-lib-icon"><i class="fa fa-share"/></div>
                                <div>
                                    <div class="sd-lib-value" t-esc="state.libraryKpis.books_issued"/>
                                    <div class="sd-lib-label">Issued</div>
                                </div>
                            </div>
                            <div class="sd-lib-item lib-overdue">
                                <div class="sd-lib-icon"><i class="fa fa-warning"/></div>
                                <div>
                                    <div class="sd-lib-value" t-esc="state.libraryKpis.overdue_books"/>
                                    <div class="sd-lib-label">Overdue</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Row 4: Tables ── -->
                <div class="sd-bottom">
                    <div class="sd-table-card">
                        <div class="sd-card-title">
                            <i class="fa fa-pencil"/> Upcoming Examinations
                        </div>
                        <div class="sd-table-wrap">
                            <t t-if="state.upcomingExams.length">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Exam</th>
                                            <th>Type</th>
                                            <th>Class</th>
                                            <th>Date</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.upcomingExams" t-as="exam" t-key="exam_index">
                                            <tr>
                                                <td t-esc="exam.name"/>
                                                <td t-esc="exam.exam_type"/>
                                                <td t-esc="exam.class_name"/>
                                                <td t-esc="exam.date_start"/>
                                                <td>
                                                    <span t-attf-class="badge bg-#{exam.state_color}"
                                                          t-esc="exam.state"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <div class="sd-empty">No upcoming examinations</div>
                            </t>
                        </div>
                    </div>

                    <div class="sd-table-card">
                        <div class="sd-card-title">
                            <i class="fa fa-bullhorn"/> Recent Announcements
                        </div>
                        <div class="sd-table-wrap">
                            <t t-if="state.announcements.length">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Title</th>
                                            <th>Audience</th>
                                            <th>Priority</th>
                                            <th>Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="state.announcements" t-as="ann" t-key="ann_index">
                                            <tr>
                                                <td t-esc="ann.title"/>
                                                <td t-esc="ann.audience"/>
                                                <td>
                                                    <span t-attf-class="sd-priority-dot #{ann.priority}"/>
                                                    <t t-esc="ann.priority"/>
                                                </td>
                                                <td t-esc="ann.date"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <div class="sd-empty">No recent announcements</div>
                            </t>
                        </div>
                    </div>
                </div>

            </t>
        </div>
    </t>
</templates>
