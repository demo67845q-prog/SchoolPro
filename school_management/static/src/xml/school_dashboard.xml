<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="SchoolDashboard">
        <div class="school-dashboard">
            <!-- Header -->
            <div class="school-dashboard-header">
                <h2>
                    <i class="fa fa-graduation-cap me-2 text-primary"/>
                    School Management Dashboard
                </h2>
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">
                        Updated: <t t-esc="state.lastUpdated"/>
                    </span>
                    <button class="school-refresh-btn" t-on-click="loadData">
                        <i class="fa fa-refresh"/> Refresh
                    </button>
                </div>
            </div>

            <!-- Loading State -->
            <t t-if="state.loading">
                <div class="school-loading">
                    <i class="fa fa-spinner fa-spin fa-2x mb-3"/>
                    <div>Loading dashboard data...</div>
                </div>
            </t>

            <t t-else="">
                <!-- Students Block -->
                <div class="school-kpi-section">
                    <h5><i class="fa fa-users me-1"/> Student Overview</h5>
                    <div class="school-kpi-grid">
                        <div class="school-kpi-card kpi-total">
                            <div class="kpi-value" t-esc="state.studentKpis.total_students"/>
                            <div class="kpi-label">Total Students</div>
                        </div>
                        <div class="school-kpi-card kpi-active">
                            <div class="kpi-value" t-esc="state.studentKpis.active_students"/>
                            <div class="kpi-label">Active</div>
                        </div>
                        <div class="school-kpi-card kpi-teachers">
                            <div class="kpi-value" t-esc="state.studentKpis.new_admissions"/>
                            <div class="kpi-label">New Admissions</div>
                        </div>
                        <div class="school-kpi-card kpi-att">
                            <div class="kpi-value" t-esc="state.studentKpis.avg_attendance + '%'"/>
                            <div class="kpi-label">Avg Attendance</div>
                        </div>
                        <div class="school-kpi-card kpi-teachers">
                            <div class="kpi-value" t-esc="state.studentKpis.total_teachers"/>
                            <div class="kpi-label">Teachers</div>
                        </div>
                        <div class="school-kpi-card kpi-classes">
                            <div class="kpi-value" t-esc="state.studentKpis.total_classes"/>
                            <div class="kpi-label">Classes</div>
                        </div>
                    </div>
                </div>

                <!-- Fee Block -->
                <div class="school-kpi-section">
                    <h5><i class="fa fa-money me-1"/> Fee Overview</h5>
                    <div class="school-kpi-grid">
                        <div class="school-kpi-card kpi-total">
                            <div class="kpi-value" t-esc="state.feeKpis.total_invoices"/>
                            <div class="kpi-label">Total Invoices</div>
                        </div>
                        <div class="school-kpi-card kpi-paid">
                            <div class="kpi-value" t-esc="state.feeKpis.paid_invoices"/>
                            <div class="kpi-label">Paid</div>
                        </div>
                        <div class="school-kpi-card kpi-pending">
                            <div class="kpi-value" t-esc="state.feeKpis.pending_invoices"/>
                            <div class="kpi-label">Pending</div>
                        </div>
                        <div class="school-kpi-card kpi-overdue">
                            <div class="kpi-value" t-esc="state.feeKpis.overdue_invoices"/>
                            <div class="kpi-label">Overdue</div>
                        </div>
                        <div class="school-kpi-card kpi-fee">
                            <div class="kpi-value" t-esc="state.feeKpis.total_due_amount"/>
                            <div class="kpi-label">Total Due</div>
                        </div>
                    </div>
                </div>

                <!-- Charts Row -->
                <div class="school-charts-row">
                    <div class="school-chart-card">
                        <h6>Student Status Distribution</h6>
                        <canvas id="schoolStudentChart" height="200"/>
                    </div>
                    <div class="school-chart-card">
                        <h6>Fee Collection Status</h6>
                        <canvas id="schoolFeeChart" height="200"/>
                    </div>
                </div>

                <!-- Library Block -->
                <div class="school-kpi-section">
                    <h5><i class="fa fa-book me-1"/> Library Overview</h5>
                    <div class="school-kpi-grid">
                        <div class="school-kpi-card kpi-books">
                            <div class="kpi-value" t-esc="state.libraryKpis.total_books"/>
                            <div class="kpi-label">Total Books</div>
                        </div>
                        <div class="school-kpi-card kpi-active">
                            <div class="kpi-value" t-esc="state.libraryKpis.books_issued"/>
                            <div class="kpi-label">Issued</div>
                        </div>
                        <div class="school-kpi-card kpi-overdue">
                            <div class="kpi-value" t-esc="state.libraryKpis.overdue_books"/>
                            <div class="kpi-label">Overdue</div>
                        </div>
                    </div>
                </div>

                <!-- Upcoming Exams Table -->
                <div class="school-table-card">
                    <h6><i class="fa fa-pencil me-1"/> Upcoming Examinations</h6>
                    <t t-if="state.upcomingExams.length">
                        <table>
                            <thead>
                                <tr>
                                    <th>Exam</th>
                                    <th>Type</th>
                                    <th>Class</th>
                                    <th>Start Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.upcomingExams" t-as="exam" t-key="exam.id">
                                    <tr>
                                        <td><t t-esc="exam.name"/></td>
                                        <td><t t-esc="exam.exam_type"/></td>
                                        <td><t t-esc="exam.class_name"/></td>
                                        <td><t t-esc="exam.date_start"/></td>
                                        <td>
                                            <span t-attf-class="badge bg-#{exam.state_color}">
                                                <t t-esc="exam.state"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="text-muted text-center py-3">No upcoming examinations.</div>
                    </t>
                </div>

                <!-- Recent Announcements -->
                <div class="school-table-card">
                    <h6><i class="fa fa-bullhorn me-1"/> Recent Announcements</h6>
                    <t t-if="state.announcements.length">
                        <table>
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Audience</th>
                                    <th>Priority</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.announcements" t-as="ann" t-key="ann.id">
                                    <tr>
                                        <td><t t-esc="ann.title"/></td>
                                        <td><t t-esc="ann.audience"/></td>
                                        <td><t t-esc="ann.priority"/></td>
                                        <td><t t-esc="ann.date"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                    <t t-else="">
                        <div class="text-muted text-center py-3">No recent announcements.</div>
                    </t>
                </div>
            </t>
        </div>
    </t>
</templates>
