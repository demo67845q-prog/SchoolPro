<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Teacher: see only students in their sections -->
        <record id="rule_teacher_students" model="ir.rule">
            <field name="name">Teacher: Own Section Students</field>
            <field name="model_id" ref="model_school_student"/>
            <field name="groups" eval="[(4, ref('group_school_teacher'))]"/>
            <field name="domain_force">[
                '|',
                ('section_id.teacher_id.user_id', '=', user.id),
                ('class_id.section_ids.teacher_id.user_id', '=', user.id)
            ]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Parent: see only their own child -->
        <record id="rule_parent_student" model="ir.rule">
            <field name="name">Parent: Own Child Only</field>
            <field name="model_id" ref="model_school_student"/>
            <field name="groups" eval="[(4, ref('group_school_parent'))]"/>
            <field name="domain_force">[('parent_user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Student: see only themselves -->
        <record id="rule_student_self" model="ir.rule">
            <field name="name">Student: Own Record Only</field>
            <field name="model_id" ref="model_school_student"/>
            <field name="groups" eval="[(4, ref('group_school_student'))]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Teacher: own attendance records only -->
        <record id="rule_teacher_own_attendance" model="ir.rule">
            <field name="name">Teacher: Own Attendance</field>
            <field name="model_id" ref="model_school_teacher_attendance"/>
            <field name="groups" eval="[(4, ref('group_school_teacher'))]"/>
            <field name="domain_force">[('teacher_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Parent: see only their child's fee invoices -->
        <record id="rule_parent_fee_invoice" model="ir.rule">
            <field name="name">Parent: Own Child Fee Invoices</field>
            <field name="model_id" ref="model_school_fee_invoice"/>
            <field name="groups" eval="[(4, ref('group_school_parent'))]"/>
            <field name="domain_force">[('student_id.parent_user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Librarian: manage library issues only -->
        <record id="rule_librarian_issues" model="ir.rule">
            <field name="name">Librarian: All Library Issues</field>
            <field name="model_id" ref="model_school_library_issue"/>
            <field name="groups" eval="[(4, ref('group_school_librarian'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Transport Manager: own routes -->
        <record id="rule_transport_manager" model="ir.rule">
            <field name="name">Transport Manager: All Routes</field>
            <field name="model_id" ref="model_school_transport_route"/>
            <field name="groups" eval="[(4, ref('group_school_transport'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Admin: no restrictions -->
        <record id="rule_admin_all_students" model="ir.rule">
            <field name="name">Admin: All Students</field>
            <field name="model_id" ref="model_school_student"/>
            <field name="groups" eval="[(4, ref('group_school_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
