<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_school_fee_invoice" model="ir.actions.report">
        <field name="name">Fee Invoice</field>
        <field name="model">school.fee.invoice</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">school_management.report_fee_invoice</field>
        <field name="report_file">school_management.report_fee_invoice</field>
        <field name="binding_model_id" ref="model_school_fee_invoice"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <template id="report_fee_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="inv">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="text-center mb-3">
                            <h2>Fee Invoice</h2>
                        </div>

                        <div class="row">
                            <div class="col-6">
                                <strong>Invoice Ref:</strong>
                                <t t-esc="inv.reference"/><br/>
                                <strong>Date:</strong>
                                <t t-esc="inv.date"/><br/>
                                <strong>Due Date:</strong>
                                <t t-esc="inv.due_date"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Student:</strong>
                                <t t-esc="inv.student_id.name"/><br/>
                                <strong>Admission No:</strong>
                                <t t-esc="inv.student_id.admission_no"/><br/>
                                <strong>Class:</strong>
                                <t t-esc="inv.student_id.class_id.name"/> -
                                <t t-esc="inv.student_id.section_id.name or ''"/>
                            </div>
                        </div>

                        <table class="table table-bordered mt-3">
                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="inv.line_ids" t-as="line">
                                    <tr>
                                        <td><t t-esc="line.name"/></td>
                                        <td class="text-end">
                                            <t t-esc="'%.2f' % line.amount"/>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="inv.late_fee">
                                    <tr>
                                        <td><em>Late Fee</em></td>
                                        <td class="text-end">
                                            <t t-esc="'%.2f' % inv.late_fee"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr class="table-secondary">
                                    <th>Total Amount</th>
                                    <th class="text-end">
                                        <t t-esc="'%.2f' % inv.total_amount"/>
                                    </th>
                                </tr>
                                <tr>
                                    <td>Amount Paid</td>
                                    <td class="text-end">
                                        <t t-esc="'%.2f' % inv.amount_paid"/>
                                    </td>
                                </tr>
                                <tr class="table-warning">
                                    <th>Balance Due</th>
                                    <th class="text-end">
                                        <t t-esc="'%.2f' % inv.amount_due"/>
                                    </th>
                                </tr>
                            </tfoot>
                        </table>

                        <t t-if="inv.payment_ids">
                            <h5>Payment History</h5>
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Receipt No</th>
                                        <th>Date</th>
                                        <th>Mode</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="inv.payment_ids" t-as="pay">
                                        <tr>
                                            <td><t t-esc="pay.receipt_no"/></td>
                                            <td><t t-esc="pay.date"/></td>
                                            <td><t t-esc="pay.payment_mode"/></td>
                                            <td class="text-end">
                                                <t t-esc="'%.2f' % pay.amount"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <div class="mt-4 text-center text-muted">
                            <em>This is a computer-generated document. No signature required.</em>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
