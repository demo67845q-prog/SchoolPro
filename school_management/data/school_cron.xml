<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Mark library books overdue -->
        <record id="cron_school_library_overdue" model="ir.cron">
            <field name="name">School: Mark Library Books Overdue</field>
            <field name="model_id" ref="school_management.model_school_library_issue"/>
            <field name="state">code</field>
            <field name="code">model._cron_mark_overdue()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Mark fee invoices overdue -->
        <record id="cron_school_fee_overdue" model="ir.cron">
            <field name="name">School: Mark Fee Invoices Overdue</field>
            <field name="model_id" ref="school_management.model_school_fee_invoice"/>
            <field name="state">code</field>
            <field name="code">model._apply_late_fee()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
