<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Student Admission Number -->
        <record id="seq_school_student" model="ir.sequence">
            <field name="name">School Student Admission</field>
            <field name="code">school.student</field>
            <field name="prefix">ADM/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Fee Invoice Reference -->
        <record id="seq_school_fee_invoice" model="ir.sequence">
            <field name="name">School Fee Invoice</field>
            <field name="code">school.fee.invoice</field>
            <field name="prefix">INV/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Fee Payment Receipt -->
        <record id="seq_school_fee_payment" model="ir.sequence">
            <field name="name">School Fee Payment Receipt</field>
            <field name="code">school.fee.payment</field>
            <field name="prefix">RCP/%(year)s/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Library Issue -->
        <record id="seq_school_library_issue" model="ir.sequence">
            <field name="name">School Library Issue</field>
            <field name="code">school.library.issue</field>
            <field name="prefix">LIB/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Teacher Employee ID -->
        <record id="seq_school_teacher" model="ir.sequence">
            <field name="name">School Teacher</field>
            <field name="code">school.teacher</field>
            <field name="prefix">TCH/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <!-- Event Code -->
        <record id="seq_school_event" model="ir.sequence">
            <field name="name">School Event</field>
            <field name="code">school.event</field>
            <field name="prefix">EVT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>
    </data>
</odoo>
