<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Period ─────────────────────────────────────────────────────────── -->
    <record id="view_school_period_list" model="ir.ui.view">
        <field name="name">school.period.list</field>
        <field name="model">school.period</field>
        <field name="arch" type="xml">
            <list string="Periods" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="is_break"/>
            </list>
        </field>
    </record>

    <record id="action_school_period" model="ir.actions.act_window">
        <field name="name">Periods</field>
        <field name="res_model">school.period</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Timetable ─────────────────────────────────────────────────────── -->
    <record id="view_school_timetable_list" model="ir.ui.view">
        <field name="name">school.timetable.list</field>
        <field name="model">school.timetable</field>
        <field name="arch" type="xml">
            <list string="Timetable">
                <field name="section_id"/>
                <field name="day_of_week"/>
                <field name="period_id"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
            </list>
        </field>
    </record>

    <record id="view_school_timetable_form" model="ir.ui.view">
        <field name="name">school.timetable.form</field>
        <field name="model">school.timetable</field>
        <field name="arch" type="xml">
            <form string="Timetable Entry">
                <sheet>
                    <group>
                        <group>
                            <field name="section_id"/>
                            <field name="day_of_week"/>
                            <field name="period_id"/>
                        </group>
                        <group>
                            <field name="subject_id"/>
                            <field name="teacher_id"/>
                            <field name="academic_year_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_timetable" model="ir.actions.act_window">
        <field name="name">Timetable</field>
        <field name="res_model">school.timetable</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
