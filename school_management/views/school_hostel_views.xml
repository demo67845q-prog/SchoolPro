<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Hostel ────────────────────────────────────────────────────────── -->
    <record id="view_school_hostel_list" model="ir.ui.view">
        <field name="name">school.hostel.list</field>
        <field name="model">school.hostel</field>
        <field name="arch" type="xml">
            <list string="Hostels">
                <field name="name"/>
                <field name="hostel_type"/>
                <field name="warden_id"/>
                <field name="warden_phone"/>
                <field name="total_rooms"/>
                <field name="occupied_rooms"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_school_hostel_form" model="ir.ui.view">
        <field name="name">school.hostel.form</field>
        <field name="model">school.hostel</field>
        <field name="arch" type="xml">
            <form string="Hostel">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Hostel Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="hostel_type"/>
                            <field name="warden_id"/>
                            <field name="warden_phone"/>
                            <field name="monthly_fee"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="address"/>
                            <field name="total_rooms" readonly="1"/>
                            <field name="occupied_rooms" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Rooms">
                            <field name="room_ids">
                                <list>
                                    <field name="room_number"/>
                                    <field name="room_type"/>
                                    <field name="floor"/>
                                    <field name="capacity"/>
                                    <field name="current_occupancy" readonly="1"/>
                                    <field name="monthly_fee"/>
                                    <field name="is_occupied" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_hostel" model="ir.actions.act_window">
        <field name="name">Hostels</field>
        <field name="res_model">school.hostel</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Hostel Allocation ──────────────────────────────────────────────── -->
    <record id="view_school_hostel_allocation_list" model="ir.ui.view">
        <field name="name">school.hostel.allocation.list</field>
        <field name="model">school.hostel.allocation</field>
        <field name="arch" type="xml">
            <list string="Hostel Allocations">
                <field name="student_id"/>
                <field name="hostel_id"/>
                <field name="room_id"/>
                <field name="academic_year_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'active'"
                    decoration-muted="state == 'vacated'"/>
            </list>
        </field>
    </record>

    <record id="view_school_hostel_allocation_form" model="ir.ui.view">
        <field name="name">school.hostel.allocation.form</field>
        <field name="model">school.hostel.allocation</field>
        <field name="arch" type="xml">
            <form string="Hostel Allocation">
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="hostel_id"/>
                            <field name="room_id" domain="[('hostel_id','=',hostel_id)]"/>
                            <field name="bed_number"/>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="monthly_fee" readonly="1"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_hostel_allocation" model="ir.actions.act_window">
        <field name="name">Hostel Allocations</field>
        <field name="res_model">school.hostel.allocation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
