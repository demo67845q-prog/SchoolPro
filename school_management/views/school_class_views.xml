<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Subject ───────────────────────────────────────────────────────── -->
    <record id="view_school_subject_list" model="ir.ui.view">
        <field name="name">school.subject.list</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <list string="Subjects">
                <field name="code"/>
                <field name="name"/>
                <field name="subject_type"/>
                <field name="max_marks"/>
                <field name="pass_marks"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_school_subject_form" model="ir.ui.view">
        <field name="name">school.subject.form</field>
        <field name="model">school.subject</field>
        <field name="arch" type="xml">
            <form string="Subject">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Subject Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="subject_type"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="max_marks"/>
                            <field name="pass_marks"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_subject" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">school.subject</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Class ─────────────────────────────────────────────────────────── -->
    <record id="view_school_class_list" model="ir.ui.view">
        <field name="name">school.class.list</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="code"/>
                <field name="sequence"/>
            </list>
        </field>
    </record>

    <record id="view_school_class_form" model="ir.ui.view">
        <field name="name">school.class.form</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Grade 10"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sections">
                            <field name="section_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="teacher_id"/>
                                    <field name="capacity"/>
                                </list>
                            </field>
                        </page>
                        <page string="Subjects">
                            <field name="subject_ids" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">school.class</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Section ───────────────────────────────────────────────────────── -->
    <record id="view_school_section_list" model="ir.ui.view">
        <field name="name">school.section.list</field>
        <field name="model">school.section</field>
        <field name="arch" type="xml">
            <list string="Sections">
                <field name="display_name"/>
                <field name="class_id"/>
                <field name="name"/>
                <field name="teacher_id"/>
                <field name="capacity"/>
            </list>
        </field>
    </record>

    <record id="action_school_section" model="ir.actions.act_window">
        <field name="name">Sections</field>
        <field name="res_model">school.section</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
