<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Homework ───────────────────────────────────────────────────────── -->
    <record id="view_school_homework_list" model="ir.ui.view">
        <field name="name">school.homework.list</field>
        <field name="model">school.homework</field>
        <field name="arch" type="xml">
            <list string="Homework">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="class_id"/>
                <field name="section_id"/>
                <field name="teacher_id"/>
                <field name="assigned_date"/>
                <field name="due_date"/>
                <field name="state" widget="badge"
                    decoration-muted="state == 'draft'"
                    decoration-info="state == 'assigned'"
                    decoration-success="state == 'closed'"/>
            </list>
        </field>
    </record>

    <record id="view_school_homework_form" model="ir.ui.view">
        <field name="name">school.homework.form</field>
        <field name="model">school.homework</field>
        <field name="arch" type="xml">
            <form string="Homework">
                <header>
                    <button name="action_assign" string="Assign" type="object"
                        class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object"
                        invisible="state != 'assigned'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,assigned,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Homework Title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="subject_id"/>
                            <field name="class_id"/>
                            <field name="section_id"/>
                            <field name="teacher_id"/>
                        </group>
                        <group>
                            <field name="assigned_date"/>
                            <field name="due_date"/>
                            <field name="academic_year_id"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Attachments">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Submissions">
                            <field name="submission_ids" readonly="1">
                                <list>
                                    <field name="student_id"/>
                                    <field name="submitted_date"/>
                                    <field name="grade"/>
                                    <field name="status" widget="badge"
                                        decoration-success="status == 'submitted'"
                                        decoration-warning="status == 'late'"
                                        decoration-danger="status == 'not_submitted'"
                                        decoration-info="status == 'pending'"/>
                                    <field name="teacher_remarks"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_homework" model="ir.actions.act_window">
        <field name="name">Homework</field>
        <field name="res_model">school.homework</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_school_homework_submission" model="ir.actions.act_window">
        <field name="name">Homework Submissions</field>
        <field name="res_model">school.homework.submission</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
