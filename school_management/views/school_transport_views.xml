<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Transport Route ───────────────────────────────────────────────── -->
    <record id="view_school_transport_route_list" model="ir.ui.view">
        <field name="name">school.transport.route.list</field>
        <field name="model">school.transport.route</field>
        <field name="arch" type="xml">
            <list string="Transport Routes">
                <field name="name"/>
                <field name="route_number"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="driver_phone"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_school_transport_route_form" model="ir.ui.view">
        <field name="name">school.transport.route.form</field>
        <field name="model">school.transport.route</field>
        <field name="arch" type="xml">
            <form string="Transport Route">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Route Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="route_number"/>
                            <field name="vehicle_id"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="driver_id"/>
                            <field name="driver_phone"/>
                            <field name="conductor_name"/>
                        </group>
                    </group>
                    <group string="Timings">
                        <field name="morning_start_time" widget="float_time"/>
                        <field name="afternoon_start_time" widget="float_time"/>
                    </group>
                    <notebook>
                        <page string="Stops">
                            <field name="stop_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="arrival_time" widget="float_time"/>
                                    <field name="landmark"/>
                                    <field name="monthly_fee"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_transport_route" model="ir.actions.act_window">
        <field name="name">Transport Routes</field>
        <field name="res_model">school.transport.route</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Transport Vehicle ─────────────────────────────────────────────── -->
    <record id="view_school_transport_vehicle_list" model="ir.ui.view">
        <field name="name">school.transport.vehicle.list</field>
        <field name="model">school.transport.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles" editable="bottom">
                <field name="name"/>
                <field name="registration_no"/>
                <field name="vehicle_type"/>
                <field name="capacity"/>
                <field name="model"/>
                <field name="insurance_expiry"/>
                <field name="fitness_expiry"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="action_school_transport_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">school.transport.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ── Transport Assignment ──────────────────────────────────────────── -->
    <record id="view_school_transport_assignment_list" model="ir.ui.view">
        <field name="name">school.transport.assignment.list</field>
        <field name="model">school.transport.assignment</field>
        <field name="arch" type="xml">
            <list string="Transport Assignments">
                <field name="student_id"/>
                <field name="route_id"/>
                <field name="stop_id"/>
                <field name="academic_year_id"/>
                <field name="pickup_type"/>
                <field name="monthly_fee"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_school_transport_assignment_form" model="ir.ui.view">
        <field name="name">school.transport.assignment.form</field>
        <field name="model">school.transport.assignment</field>
        <field name="arch" type="xml">
            <form string="Transport Assignment">
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="academic_year_id"/>
                            <field name="route_id"/>
                        </group>
                        <group>
                            <field name="stop_id" domain="[('route_id','=',route_id)]"/>
                            <field name="pickup_type"/>
                            <field name="monthly_fee" readonly="1"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_school_transport_assignment" model="ir.actions.act_window">
        <field name="name">Student Transport</field>
        <field name="res_model">school.transport.assignment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
