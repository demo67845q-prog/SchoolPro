<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_school_teacher_list" model="ir.ui.view">
        <field name="name">school.teacher.list</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <list string="Teachers" decoration-muted="state in ('resigned','terminated')">
                <field name="employee_id"/>
                <field name="name"/>
                <field name="designation"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="experience_years"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'active'"
                    decoration-warning="state == 'on_leave'"
                    decoration-muted="state in ('resigned','terminated')"/>
            </list>
        </field>
    </record>

    <record id="view_school_teacher_form" model="ir.ui.view">
        <field name="name">school.teacher.form</field>
        <field name="model">school.teacher</field>
        <field name="arch" type="xml">
            <form string="Teacher">
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="active,on_leave,resigned"/>
                </header>
                <sheet>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Teacher Full Name"/></h1>
                        <field name="employee_id" readonly="1"/>
                    </div>
                    <notebook>
                        <page string="Professional Info">
                            <group>
                                <group>
                                    <field name="designation"/>
                                    <field name="qualification"/>
                                    <field name="specialization"/>
                                    <field name="experience_years"/>
                                    <field name="joining_date"/>
                                </group>
                                <group>
                                    <field name="phone"/>
                                    <field name="email"/>
                                    <field name="address"/>
                                    <field name="user_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Personal Info">
                            <group>
                                <group>
                                    <field name="date_of_birth"/>
                                    <field name="gender"/>
                                    <field name="blood_group"/>
                                    <field name="nationality"/>
                                    <field name="marital_status"/>
                                </group>
                            </group>
                        </page>
                        <page string="Subjects &amp; Sections">
                            <group string="Subjects Taught">
                                <field name="subject_ids" widget="many2many_tags" nolabel="1"/>
                            </group>
                            <group string="Class Teacher Of">
                                <field name="section_ids" nolabel="1" readonly="1">
                                    <list>
                                        <field name="display_name"/>
                                        <field name="class_id"/>
                                        <field name="capacity"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_school_teacher" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">school.teacher</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
